FROM python:3.12-slim

WORKDIR /app

COPY requirements-miniapp.txt .
RUN pip install --no-cache-dir -r requirements-miniapp.txt

# Слой данных и сервисы переиспользуются из кода бота как есть.
COPY database/ ./database/
COPY services/ ./services/
COPY miniapp/ ./miniapp/

EXPOSE 8099

# Запуск из корня проекта — тогда `database` и `services` импортируются обычным образом,
# без правки sys.path.
CMD ["uvicorn", "miniapp.main:app", "--host", "0.0.0.0", "--port", "8099"]
