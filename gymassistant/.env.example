# --- общее ---
DB_URL=postgresql+asyncpg://username:password@127.0.0.1:5432/database?ssl=disable
NEIRO_API_URL=http://127.0.0.1:8000/predict

# --- бот ---
TOKEN=bot_token
ADMIN_IDS=123456789

# Провайдер режет подсети Telegram, поэтому бот ходит наружу только через SOCKS5
# и работает поллингом: webhook упирается в ту же блокировку.
PROXY_URL=socks5://127.0.0.1:1080
USE_POLLING=true

# Куда ведёт кнопка меню бота.
MINIAPP_URL=https://sk1bid.ru/gym/

# Webhook не используется, но код его ещё поддерживает.
WEBHOOK_HOST=your_domain
WEBHOOK_PATH=/path/to/webhook
WEBHOOK_SECRET=random_64_bit_seed
PORT=8081

# --- Mini App ---
# Токен нужен не для походов в Telegram (их нет), а чтобы проверять подпись initData.
MINIAPP_BOT_TOKEN=bot_token
MINIAPP_MAX_AUTH_AGE=86400
